<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only: permit cleartext HTTP to the local dev backend ONLY — the device
  loopback (127.0.0.1, reached via `adb reverse tcp:8080 tcp:8080`) and the
  emulator's host alias (10.0.2.2). Everything else keeps the platform default
  (cleartext blocked). This file is not packaged in release builds.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
