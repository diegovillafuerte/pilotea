<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- OTA parser-config fetch + consented aggregate sync talk to the thin backend. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Service-health watchdog: alert the driver if an OEM task killer disables the reader (B-036).
         Requested contextually on the onboarding done screen on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- The reader-stopped channel vibrates (B-078) — the reader dies at screen lock, phone in
         pocket, so the alert must be felt. Normal permission, granted at install. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!--
      Package visibility (Android 11+) for the shareable earnings card (B-055): so we can detect
      WhatsApp (preferred share target) and resolve ACTION_SEND image targets for the chooser fallback.
    -->
    <queries>
        <package android:name="com.whatsapp" />
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="image/png" />
        </intent>
        <!-- Resolve ACTION_SEND PDF targets for the fiscal-report export chooser (B-052). -->
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="application/pdf" />
        </intent>
    </queries>

    <!--
      allowBackup="false": the privacy posture is "nothing about your screen/offers leaves the
      device" (docs/play-compliance.md). Auto cloud/adb backup would ship the local Room ledger AND
      the session token (stored in DataStore, plaintext — TD-009) off-device to Google's backup,
      both contradicting that promise and creating a token-in-backup account-takeover vector. The
      cost is that a device migration re-onboards (WhatsApp OTP re-auth + re-enter cost profile),
      acceptable for a privacy-first tool. Revisit with a scoped dataExtractionRules Xml only if a
      selective backup that excludes the token + ledger is ever wanted. -->
    <application
        android:name=".KomparaApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kompara">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!--
              Referral deep link (B-056): kompara://referral?code=XXXXXXXX. Opens the "Invita y gana"
              screen and prefills the code once the driver is signed in. Handled in MainActivity.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="kompara" android:host="referral" />
            </intent-filter>
        </activity>

        <!-- Inbound earnings-file share-target (PR-D3): appears in the OS Share sheet as "Kompara —
             Importar ganancias" so a driver shares their Uber PDF / DiDi screenshots straight from Uber
             Driver / DiDi / Gmail / Gallery. Exported (a share target must be) but does nothing
             privileged — it only reads the bytes the user explicitly shared and bounces into the import
             flow; it NEVER touches the MediaProjection/OcrConsent path. Translucent + no-history +
             excludeFromRecents + isolated task so it shows no UI of its own and never lingers in
             Recents. android:label is what the share sheet displays. -->
        <activity
            android:name=".ShareImportActivity"
            android:exported="true"
            android:label="@string/share_import_label"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/pdf" />
                <data android:mimeType="image/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
        </activity>

        <!-- OCR capture consent entry. Launched ONLY from inside the app — the Lector tab button
             and the reader-stopped notification, both via the package-scoped action below (B-075;
             the literal must match ScreenReaderState.ACTION_START). NOT exported: this is a
             sensitive MediaProjection entry point, and other apps must never be able to trigger
             the consent flow past our prominent disclosure. Isolated in its own task
             (taskAffinity="" + excludeFromRecents + finishOnTaskLaunch) so the launcher icon can
             never resume it instead of MainActivity (it would otherwise re-prompt for screen
             sharing and trap the user). Deliberately NOT noHistory: a no-history activity is
             finished if the system consent UI ever fully covers it, dropping the activity result —
             it finishes itself after the result instead. -->
        <activity
            android:name=".OcrConsentActivity"
            android:exported="false"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="mx.kompara.action.START_SCREEN_READER" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!--
          On-demand WorkManager initialization (B-033): the app supplies its own Configuration via
          KomparaApplication (Configuration.Provider) so periodic work runs through the
          HiltWorkerFactory. Removing the default initializer is required for that to take effect.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!--
          FileProvider for the shareable earnings card PNGs (B-055). Authority = applicationId +
          ".fileprovider" (matches ShareCardWriter.AUTHORITY_SUFFIX); paths in res/xml/file_paths.xml
          (from :ui) expose only the share_cards/ cache subdir. grantUriPermissions lets the
          ACTION_SEND read-grant reach the share target.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
