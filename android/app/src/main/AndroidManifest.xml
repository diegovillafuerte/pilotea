<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- OTA parser-config fetch + consented aggregate sync talk to the thin backend. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Service-health watchdog: alert the driver if an OEM task killer disables the reader (B-036).
         Requested contextually on the onboarding done screen on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Package visibility (Android 11+) for the shareable earnings card (B-055): so we can detect
      WhatsApp (preferred share target) and resolve ACTION_SEND image targets for the chooser fallback.
    -->
    <queries>
        <package android:name="com.whatsapp" />
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="image/png" />
        </intent>
    </queries>

    <application
        android:name=".KomparaApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kompara">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!--
              Referral deep link (B-056): kompara://referral?code=XXXXXXXX. Opens the "Invita y gana"
              screen and prefills the code once the driver is signed in. Handled in MainActivity.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="kompara" android:host="referral" />
            </intent-filter>
        </activity>

        <!--
          On-demand WorkManager initialization (B-033): the app supplies its own Configuration via
          KomparaApplication (Configuration.Provider) so periodic work runs through the
          HiltWorkerFactory. Removing the default initializer is required for that to take effect.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!--
          FileProvider for the shareable earnings card PNGs (B-055). Authority = applicationId +
          ".fileprovider" (matches ShareCardWriter.AUTHORITY_SUFFIX); paths in res/xml/file_paths.xml
          (from :ui) expose only the share_cards/ cache subdir. grantUriPermissions lets the
          ACTION_SEND read-grant reach the share target.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
