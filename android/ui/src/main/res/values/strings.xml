    <!-- Pitch de valor (3 páginas) -->
    <string name="onb_pitch_1_titulo">Sabe si conviene antes de aceptar</string>
    <string name="onb_pitch_1_cuerpo">Kompara lee la oferta en tu pantalla y te dice al instante, con un semáforo, si ese viaje te deja ganancia de verdad — antes de que toques \"Aceptar\".</string>
    <string name="onb_pitch_2_titulo">Hasta un +30%% mejor por turno</string>
    <string name="onb_pitch_2_cuerpo">Rechazar los viajes que no convienen sube tu ganancia por hora. Es el promedio reportado por apps similares; tus resultados dependen de tu zona y tus horarios.</string>
    <string name="onb_pitch_3_titulo">Tus datos nunca salen de tu teléfono</string>
    <string name="onb_pitch_3_cuerpo">Todo el cálculo ocurre en tu celular. Kompara funciona sin cuenta y no vende ni comparte lo que aparece en tu pantalla.</string>
    <string name="onb_pitch_cta">Empezar</string>

    <!-- ===== Divulgación destacada (Prominent disclosure) =====       -->
    <!-- TODO(legal-B038): COPIA PROVISIONAL. Debe ser revisada y         -->
    <!-- aprobada por asesoría legal (tarea B-038) ANTES del lanzamiento. -->
    <!-- La estructura cumple el estándar de "prominent disclosure" de    -->
    <!-- Google Play: qué se lee, por qué, dónde se procesa, consentimiento -->
    <!-- explícito y advertencia de riesgo de Términos de Servicio.       -->
    <string name="onb_disc_titulo">Antes de continuar: qué hace Kompara</string>
    <string name="onb_disc_intro">Para darte el veredicto de cada viaje, Kompara necesita usar el servicio de accesibilidad de Android. Lee esto con calma antes de aceptar.</string>
    <string name="onb_disc_que_titulo">Qué lee</string>
    <!-- TODO(legal-B038) -->
    <string name="onb_disc_que_cuerpo">Kompara lee el contenido de pantalla de las apps de Uber y DiDi mientras manejas — los textos de la oferta del viaje (tarifa, distancia, tiempo y destino).</string>
    <string name="onb_disc_porque_titulo">Para qué</string>
    <!-- TODO(legal-B038) -->
    <string name="onb_disc_porque_cuerpo">Únicamente para calcular las métricas del viaje (ganancia por km, por hora y por viaje) y mostrarte el semáforo de si conviene o no.</string>
    <string name="onb_disc_donde_titulo">Dónde se procesa</string>
    <!-- TODO(legal-B038) -->
    <string name="onb_disc_donde_cuerpo">El procesamiento ocurre solo en tu teléfono. Kompara no vende, no comparte ni sube a internet el contenido de tu pantalla. La app funciona sin cuenta.</string>
    <string name="onb_disc_riesgo_titulo">Riesgo a tener en cuenta</string>
    <!-- TODO(legal-B038) -->
    <string name="onb_disc_riesgo_cuerpo">Usar herramientas de terceros puede contravenir los términos de las plataformas (Uber, DiDi). Kompara solo lee información y nunca actúa por ti dentro de esas apps, pero la decisión de usarla es tuya y bajo tu responsabilidad.</string>
    <string name="onb_disc_aceptar">Aceptar y continuar</string>
    <string name="onb_disc_rechazar">No acepto</string>

    <!-- Pantalla limitada (tras rechazar la divulgación) -->
    <string name="onb_limit_titulo">Sin el lector, Kompara es limitada</string>
    <string name="onb_limit_cuerpo">Respetamos tu decisión. Sin el servicio de accesibilidad no podemos leer las ofertas, así que el semáforo en tiempo real no estará disponible. Aún puedes registrar viajes a mano y ver tu resumen fiscal. Puedes activar el lector cuando quieras desde Ajustes.</string>
