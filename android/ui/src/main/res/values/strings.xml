    <!-- Pitch de valor (3 páginas) -->
    <string name="onb_pitch_1_titulo">Sabe si conviene antes de aceptar</string>
    <string name="onb_pitch_1_cuerpo">Kompara lee la oferta en tu pantalla y te dice al instante, con un semáforo, si ese viaje te deja ganancia de verdad — antes de que toques \"Aceptar\".</string>
    <string name="onb_pitch_2_titulo">Hasta un +30%% mejor por turno</string>
    <string name="onb_pitch_2_cuerpo">Rechazar los viajes que no convienen sube tu ganancia por hora. Es el promedio reportado por apps similares; tus resultados dependen de tu zona y tus horarios.</string>
    <string name="onb_pitch_3_titulo">Tus datos nunca salen de tu teléfono</string>
    <string name="onb_pitch_3_cuerpo">Todo el cálculo ocurre en tu celular. Kompara funciona sin cuenta y no vende ni comparte lo que aparece en tu pantalla.</string>
    <string name="onb_pitch_cta">Empezar</string>

    <!-- ===== Divulgación destacada (Prominent disclosure) =====       -->
    <!-- TODO(legal-B038): COPIA PROVISIONAL. Debe ser revisada y         -->
    <!-- aprobada por asesoría legal (tarea B-038) ANTES del lanzamiento. -->
    <!-- La estructura cumple el estándar de "prominent disclosure" de    -->
    <!-- Google Play: qué se lee, por qué, dónde se procesa, consentimiento -->
    <!-- explícito y advertencia de riesgo de Términos de Servicio.       -->
    <string name="onb_disc_titulo">Antes de continuar: qué hace Kompara</string>
    <string name="onb_disc_intro">Para darte el veredicto de cada viaje, Kompara necesita usar el servicio de accesibilidad de Android. Lee esto con calma antes de aceptar.</string>
    <string name="onb_disc_que_titulo">Qué lee</string>
    <!-- TODO(legal-B038) -->
    <string name="onb_disc_que_cuerpo">Kompara lee el contenido de pantalla de las apps de Uber y DiDi mientras manejas — los textos de la oferta del viaje (tarifa, distancia, tiempo y destino).</string>
    <string name="onb_disc_porque_titulo">Para qué</string>
    <!-- TODO(legal-B038) -->
    <string name="onb_disc_porque_cuerpo">Únicamente para calcular las métricas del viaje (ganancia por km, por hora y por viaje) y mostrarte el semáforo de si conviene o no.</string>
    <string name="onb_disc_donde_titulo">Dónde se procesa</string>
    <!-- TODO(legal-B038) -->
    <string name="onb_disc_donde_cuerpo">El procesamiento ocurre solo en tu teléfono. Kompara no vende, no comparte ni sube a internet el contenido de tu pantalla. La app funciona sin cuenta.</string>
    <string name="onb_disc_riesgo_titulo">Riesgo a tener en cuenta</string>
    <!-- TODO(legal-B038) -->
    <string name="onb_disc_riesgo_cuerpo">Usar herramientas de terceros puede contravenir los términos de las plataformas (Uber, DiDi). Kompara solo lee información y nunca actúa por ti dentro de esas apps, pero la decisión de usarla es tuya y bajo tu responsabilidad.</string>
    <string name="onb_disc_aceptar">Aceptar y continuar</string>
    <string name="onb_disc_rechazar">No acepto</string>

    <!-- Pantalla limitada (tras rechazar la divulgación) -->
    <string name="onb_limit_titulo">Sin el lector, Kompara es limitada</string>
    <string name="onb_limit_cuerpo">Respetamos tu decisión. Sin el servicio de accesibilidad no podemos leer las ofertas, así que el semáforo en tiempo real no estará disponible. Aún puedes registrar viajes a mano y ver tu resumen fiscal. Puedes activar el lector cuando quieras desde Ajustes.</string>
    <string name="onb_limit_revisar">Revisar de nuevo</string>
    <string name="onb_limit_continuar">Continuar sin el lector</string>

    <!-- Concesión de accesibilidad -->
    <string name="onb_acc_titulo">Activa el lector de Kompara</string>
    <string name="onb_acc_intro">Te llevamos a los Ajustes de accesibilidad de Android. Sigue estos pasos:</string>
    <string name="onb_acc_paso_1">1. Busca \"Kompara\" en la lista de servicios.</string>
    <string name="onb_acc_paso_2">2. Toca Kompara y activa el interruptor.</string>
    <string name="onb_acc_paso_3">3. Confirma en el aviso del sistema y regresa aquí.</string>
    <string name="onb_acc_boton">Abrir ajustes de accesibilidad</string>
    <string name="onb_acc_esperando">Esperando a que actives el lector…</string>
    <string name="onb_acc_listo_titulo">¡Listo! El lector está activo</string>
    <string name="onb_acc_listo_cuerpo">Kompara ya puede leer tus ofertas y darte el veredicto al instante.</string>

    <!-- Kit de supervivencia OEM -->
    <string name="onb_oem_titulo">Que tu teléfono no apague el lector</string>
    <string name="onb_oem_intro">Tu teléfono puede cerrar Kompara en segundo plano para ahorrar batería. Sigue estos pasos para que siga funcionando mientras manejas:</string>
    <string name="onb_oem_bateria_boton">Abrir ajustes de batería</string>
    <string name="onb_oem_recientes_tip">Tip: en la pantalla de apps recientes, mantén presionada la tarjeta de Kompara y elige el candado para fijarla y que no se cierre sola.</string>
    <string name="onb_oem_boton_continuar">Ya lo configuré</string>

    <!-- Pasos por fabricante (dontkillmyapp). -->
    <string name="onb_oem_xiaomi_1">Activa el inicio automático: Ajustes → Apps → Kompara → Inicio automático.</string>
    <string name="onb_oem_xiaomi_2">Sin restricciones de batería: Ajustes → Batería → Kompara → Sin restricciones.</string>
    <string name="onb_oem_xiaomi_3">En Recientes, fija Kompara con el candado para que MIUI/HyperOS no la cierre.</string>
    <string name="onb_oem_oppo_1">Permite el inicio automático: Ajustes → Apps → Kompara → Permitir inicio automático.</string>
    <string name="onb_oem_oppo_2">Uso de batería: Ajustes → Batería → Kompara → Permitir actividad en segundo plano.</string>
    <string name="onb_oem_oppo_3">En Recientes, fija Kompara con el candado (ColorOS suele cerrarla).</string>
    <string name="onb_oem_vivo_1">Activa el inicio automático: Ajustes → Apps → Inicio automático → activa Kompara.</string>
    <string name="onb_oem_vivo_2">Alto consumo en segundo plano: Ajustes → Batería → Consumo elevado → permite Kompara.</string>
    <string name="onb_oem_vivo_3">En Recientes, fija Kompara con el candado (Funtouch/OriginOS la cierra agresivamente).</string>
    <string name="onb_oem_samsung_1">Quita Kompara de \"Apps en suspensión\": Ajustes → Batería → Límites de uso en segundo plano.</string>
    <string name="onb_oem_samsung_2">Sin restricción: Ajustes → Apps → Kompara → Batería → Sin restricciones.</string>
    <string name="onb_oem_huawei_1">Gestión manual de inicio: Ajustes → Batería → Inicio de apps → Kompara → administrar manualmente y activar todo.</string>
    <string name="onb_oem_huawei_2">En Recientes, fija Kompara con el candado para que EMUI/HarmonyOS no la cierre.</string>
    <string name="onb_oem_generic_1">Permite la actividad en segundo plano de Kompara en los ajustes de batería.</string>
    <string name="onb_oem_generic_2">En Recientes, fija Kompara para que el sistema no la cierre.</string>

    <!-- Pantalla final / listo -->
    <string name="onb_done_titulo">¡Todo listo para manejar!</string>
    <string name="onb_done_cuerpo">Kompara ya está leyendo tus ofertas. Prueba el lector con un viaje de ejemplo para ver cómo se ve el veredicto.</string>
