    <!-- ============================================================= -->
    <!-- Simulador de viajes (B-037)                                   -->
    <!-- Demo en la app: reproduce viajes reales por el motor real.    -->
    <!-- ============================================================= -->
    <string name="sim_title">Simulador de viajes</string>
    <string name="sim_intro">Así se ve Kompara mientras manejas: te llega un viaje y, al instante, te decimos cuánto ganas de verdad — después de gasolina y desgaste.</string>

    <!-- Platform toggle -->
    <string name="sim_platform_uber">Uber</string>
    <string name="sim_platform_didi">DiDi</string>
    <string name="sim_platform_toggle_desc">Cambia entre viajes de ejemplo de Uber y DiDi</string>

