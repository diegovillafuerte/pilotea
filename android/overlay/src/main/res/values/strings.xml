    <string name="sim_mock_didi_header">Nuevo viaje · DiDi</string>
    <string name="sim_mock_card_desc">Ejemplo de tarjeta de viaje con el veredicto de Kompara encima</string>

    <!-- Guided script: per-shape headline. %1$s = net $/km, e.g. "$15.00/km". -->
    <string name="sim_verdict_good">Verde: ganas %1$s neto — conviene</string>
    <string name="sim_verdict_marginal">Amarillo: %1$s neto — está en el límite</string>
    <string name="sim_verdict_bad">Rojo: solo %1$s neto — no conviene</string>

    <!-- Guided script: why. Spanish explanations referencing cost profile + pickup leg. -->
    <string name="sim_why_good">La tarifa es buena para la distancia y el punto de recogida está cerca, así que casi todo lo que ves se queda en tu bolsillo después de gasolina y desgaste.</string>
    <string name="sim_why_marginal">Apenas pasa uno de tus pisos. El viaje rinde por hora, pero los kilómetros — sumando el trayecto para recoger — dejan poca ganancia por km una vez que descuentas tus costos.</string>
    <string name="sim_why_bad">El punto de recogida está lejos: esos kilómetros muertos gastan gasolina sin pagarte. Al restar tus costos, lo que queda por km y por hora cae por debajo de tus pisos.</string>

