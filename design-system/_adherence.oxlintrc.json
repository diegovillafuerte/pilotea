{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/metrics/**",
              "components/navigation/**",
              "components/verdict/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|icon|key|ref|className|style|children)$/]",
        "message": "<NavTab> doesn't accept that prop. Declared props: key, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|disabled|icon|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, disabled, icon, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|interactive|padding|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tone, interactive, padding, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|children|confirmText|cancelText|onConfirm|onCancel|destructive|style|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, title, children, confirmText, cancelText, onConfirm, onCancel, destructive, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|body|ctaText|onCta|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, body, ctaText, onCta, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|badge|style|key|ref|className|style|children)$/]",
        "message": "<MetricCard> doesn't accept that prop. Declared props: label, value, badge, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OtpInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|length|style|key|ref|className|style|children)$/]",
        "message": "<OtpInput> doesn't accept that prop. Declared props: value, onChange, length, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PercentileBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:topPercent|locked|style|key|ref|className|style|children)$/]",
        "message": "<PercentileBadge> doesn't accept that prop. Declared props: topPercent, locked, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PercentileBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:displayPercentile|highlightColor|style|key|ref|className|style|children)$/]",
        "message": "<PercentileBar> doesn't accept that prop. Declared props: displayPercentile, highlightColor, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|tone|height|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, tone, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RecommendationCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|title|body|style|key|ref|className|style|children)$/]",
        "message": "<RecommendationCard> doesn't accept that prop. Declared props: type, title, body, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|valueText|value|min|max|step|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: label, valueText, value, min, max, step, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<StatusChip> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|placeholder|prefix|hint|error|type|inputMode|maxLength|style|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, value, onChange, placeholder, prefix, hint, error, type, inputMode, maxLength, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='VerdictBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|label|style|key|ref|className|style|children)$/]",
        "message": "<VerdictBadge> doesn't accept that prop. Declared props: level, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='VerdictChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|heroRate|secondaryRate|missingHint|style|key|ref|className|style|children)$/]",
        "message": "<VerdictChip> doesn't accept that prop. Declared props: level, heroRate, secondaryRate, missingHint, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
