# Kompara backend environment.
# Copy to .env and fill in. NEVER commit a real .env.

# Postgres connection string (managed Postgres in production).
DATABASE_URL=postgres://user:password@localhost:5432/kompara

# HTTP port the service listens on (Render sets this automatically).
PORT=8080

# WhatsApp OTP delivery via Twilio. When BOTH SID and token are present the
# backend sends real WhatsApp messages; otherwise it falls back to a dev logger
# that prints the OTP to the console (used in local dev and CI).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Defaults to Twilio's shared WhatsApp sandbox sender when unset.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Claude Vision (import endpoint, POST /v1/imports). Reads ANTHROPIC_API_KEY for
# the Anthropic SDK. CLAUDE_VISION_MODEL overrides the ported production model.
ANTHROPIC_API_KEY=
# CLAUDE_VISION_MODEL=claude-sonnet-4-20250514

# Object storage for uploaded import originals (Cloudflare R2 / S3-compatible).
# When ALL FOUR are set the backend stores originals in R2; otherwise it falls
# back to an in-memory store (local dev / CI — nothing is persisted).
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
